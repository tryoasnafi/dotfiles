# Brewfile - declarative toolchain for the Neovim dev setup.
# Reproduce on a new Mac with: brew bundle --file=~/asnafi/dotfiles/Brewfile

# Editor
brew "neovim"

# Core CLI tools LazyVim relies on
brew "ripgrep"   # live grep / telescope
brew "fd"        # fast file find
brew "fzf"       # fuzzy finder
brew "lazygit"   # <leader>gg git UI
brew "git"

# GitLab CLI - MR workflow, gitlab.nvim auth
brew "glab"

# Terminal emulator
cask "wezterm"

# Nerd Font for icons (LazyVim requires one). Pick this as your terminal font.
cask "font-jetbrains-mono-nerd-font"
